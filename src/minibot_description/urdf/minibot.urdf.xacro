<?xml version="1.0"?>
<robot name="minibot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="charcoal">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="terracotta">
    <color rgba="0.7 0.3 0.2 1.0"/>
  </material>
  <material name="sand">
    <color rgba="0.76 0.70 0.50 1.0"/>
  </material>
  <material name="slate_blue">
    <color rgba="0.25 0.31 0.36 1.0"/>
  </material>
  <material name="muddy_brown">
    <color rgba="0.4 0.3 0.2 1.0"/>
  </material>
  <material name="matte_black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.04615" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.27692 0.23077 0.03077"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.27692 0.23077 0.03077"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="3.6414"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.01646" ixy="0.0" ixz="0.0" iyy="0.02353" iyz="0.0" izz="0.03947"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.06154 0.13846 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="20" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.04615" length="0.03846"/>
      </geometry>
      <material name="terracotta"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04615" length="0.03846"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.7283"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000474" ixy="0.0" ixz="0.0" iyy="0.000474" iyz="0.0" izz="0.000776"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.06154 -0.13846 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="20" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.04615" length="0.03846"/>
      </geometry>
      <material name="terracotta"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04615" length="0.03846"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.7283"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000474" ixy="0.0" ixz="0.0" iyy="0.000474" iyz="0.0" izz="0.000776"/>
    </inertial>
  </link>

  <joint name="front_left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_caster"/>
    <origin xyz="0.09231 0.08462 -0.02308" rpy="0 0 0"/>
  </joint>

  <link name="front_left_caster">
    <visual>
      <geometry>
        <sphere radius="0.02308"/>
      </geometry>
      <material name="sand"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02308"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1457"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000031" ixy="0.0" ixz="0.0" iyy="0.000031" iyz="0.0" izz="0.000031"/>
    </inertial>
  </link>

  <joint name="front_right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_right_caster"/>
    <origin xyz="0.09231 -0.08462 -0.02308" rpy="0 0 0"/>
  </joint>

  <link name="front_right_caster">
    <visual>
      <geometry>
        <sphere radius="0.02308"/>
      </geometry>
      <material name="sand"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02308"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1457"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000031" ixy="0.0" ixz="0.0" iyy="0.000031" iyz="0.0" izz="0.000031"/>
    </inertial>
  </link>

  <joint name="battery_joint" type="fixed">
    <parent link="base_link"/>
    <child link="battery_link"/>
    <origin xyz="0.0 0.0 0.03846" rpy="0 0 0"/>
  </joint>

  <link name="battery_link">
    <visual>
      <geometry>
        <box size="0.23077 0.10769 0.04615"/>
      </geometry>
      <material name="muddy_brown"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.23077 0.10769 0.04615"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.1848"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00250" ixy="0.0" ixz="0.0" iyy="0.01008" iyz="0.0" izz="0.01181"/>
    </inertial>
  </link>

  <joint name="orin_joint" type="fixed">
    <parent link="battery_link"/>
    <child link="orin_link"/>
    <origin xyz="0.0 0.0 0.07308" rpy="0 0 0"/>
  </joint>

  <link name="orin_link">
    <visual>
      <geometry>
        <box size="0.16154 0.16154 0.10000"/>
      </geometry>
      <material name="slate_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.16154 0.16154 0.10000"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5490"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00767" ixy="0.0" ixz="0.0" iyy="0.00767" iyz="0.0" izz="0.01112"/>
    </inertial>
  </link>

  <joint name="camera_rods_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_rods_link"/>
    <origin xyz="0.12308 0.0 0.01538" rpy="0 0 0"/>
  </joint>

  <link name="camera_rods_link">
    <visual>
      <origin xyz="0.0 0.07692 0.10192" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.00615" length="0.20385"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <visual>
      <origin xyz="0.0 -0.07692 0.10192" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.00615" length="0.20385"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <visual>
      <origin xyz="0.0 0.0 0.20538" rpy="0 0 0"/>
      <geometry>
        <box size="0.03077 0.18462 0.00308"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.07692 0.10192" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.00615" length="0.20385"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.0 -0.07692 0.10192" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.00615" length="0.20385"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.0 0.0 0.20538" rpy="0 0 0"/>
      <geometry>
        <box size="0.03077 0.18462 0.00308"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1821"/>
      <origin xyz="0.0 0.0 0.11731"/>
      <inertia ixx="0.000396" ixy="0.0" ixz="0.0" iyy="0.000302" iyz="0.0" izz="0.000112"/>
    </inertial>
  </link>

  <joint name="zed2i_camera_joint" type="fixed">
    <parent link="camera_rods_link"/>
    <child link="zed2i_camera_link"/>
    <origin xyz="0.01538 0.0 0.23846" rpy="0 0 0"/>
  </joint>

  <link name="zed2i_camera_link">
    <visual>
      <geometry>
        <box size="0.04615 0.26923 0.06615"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04615 0.26923 0.06615"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5826"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.003732" ixy="0.0" ixz="0.0" iyy="0.000207" iyz="0.0" izz="0.003628"/>
    </inertial>
  </link>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="zed2i_camera_link"/>
    <child link="camera_link_optical"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>
  <link name="camera_link_optical"/>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>$(find minibot_control)/config/controllers.yaml</parameters>
      <hold_joints>false</hold_joints>
    </plugin>
  </gazebo>

  <gazebo reference="front_left_caster">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <gazebo reference="front_right_caster">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <gazebo reference="left_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="orin_link">
      <sensor name="minibot_imu" type="imu">
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <visualize>true</visualize>
        <topic>imu</topic>
        <ignition_frame_id>orin_link</ignition_frame_id>
      </sensor>
    </gazebo>

  <gazebo reference="zed2i_camera_link">
    <sensor name="zed2i" type="rgbd">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <horizontal_fov>1.91986</horizontal_fov> <image>
        <width>1280</width>
        <height>720</height>
        <format>R8G8B8</format>
      </image>
      <clip>
        <near>0.3</near>
        <far>20.0</far>
      </clip>
      <topic>camera</topic>
      <ignition_frame_id>camera_link_optical</ignition_frame_id>
    </sensor>
  </gazebo>

</robot>