<?xml version="1.0"?>
<robot name="minibot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="charcoal">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="terracotta">
    <color rgba="0.7 0.3 0.2 1.0"/>
  </material>
  <material name="sand">
    <color rgba="0.76 0.70 0.50 1.0"/>
  </material>
  <material name="slate_blue">
    <color rgba="0.25 0.31 0.36 1.0"/>
  </material>
  <material name="muddy_brown">
    <color rgba="0.4 0.3 0.2 1.0"/>
  </material>
  <material name="matte_black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.18 0.15 0.02"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.18 0.15 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00191" ixy="0.0" ixz="0.0" iyy="0.00273" iyz="0.0" izz="0.00458"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.04 0.09 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="20" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.025"/>
      </geometry>
      <material name="terracotta"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.20"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000055" ixy="0.0" ixz="0.0" iyy="0.000055" iyz="0.0" izz="0.00009"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.04 -0.09 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="20" velocity="20"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.025"/>
      </geometry>
      <material name="terracotta"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.20"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000055" ixy="0.0" ixz="0.0" iyy="0.000055" iyz="0.0" izz="0.00009"/>
    </inertial>
  </link>

  <joint name="front_left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_caster"/>
    <origin xyz="0.06 0.055 -0.015" rpy="0 0 0"/>
  </joint>

  <link name="front_left_caster">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="sand"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.04"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0000036" ixy="0.0" ixz="0.0" iyy="0.0000036" iyz="0.0" izz="0.0000036"/>
    </inertial>
  </link>

  <joint name="front_right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_right_caster"/>
    <origin xyz="0.06 -0.055 -0.015" rpy="0 0 0"/>
  </joint>

  <link name="front_right_caster">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="sand"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.04"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0000036" ixy="0.0" ixz="0.0" iyy="0.0000036" iyz="0.0" izz="0.0000036"/>
    </inertial>
  </link>

  <joint name="battery_joint" type="fixed">
    <parent link="base_link"/>
    <child link="battery_link"/>
    <origin xyz="0.0 0.0 0.025" rpy="0 0 0"/>
  </joint>

  <!-- FIX: removed stray <hold_joints> tag that was incorrectly placed inside this link's collision block -->
  <link name="battery_link">
    <visual>
      <geometry>
        <box size="0.15 0.07 0.03"/>
      </geometry>
      <material name="muddy_brown"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.15 0.07 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00029" ixy="0.0" ixz="0.0" iyy="0.00117" iyz="0.0" izz="0.00137"/>
    </inertial>
  </link>

  <joint name="orin_joint" type="fixed">
    <parent link="battery_link"/>
    <child link="orin_link"/>
    <origin xyz="0.0 0.0 0.0475" rpy="0 0 0"/>
  </joint>

  <link name="orin_link">
    <visual>
      <geometry>
        <box size="0.105 0.105 0.065"/>
      </geometry>
      <material name="slate_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.105 0.105 0.065"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.7"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00089" ixy="0.0" ixz="0.0" iyy="0.00089" iyz="0.0" izz="0.00129"/>
    </inertial>
  </link>

  <joint name="camera_rods_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_rods_link"/>
    <origin xyz="0.08 0.0 0.01" rpy="0 0 0"/>
  </joint>

  <link name="camera_rods_link">
    <visual>
      <origin xyz="0.0 0.05 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.004" length="0.10"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <visual>
      <origin xyz="0.0 -0.05 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.004" length="0.10"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <visual>
      <origin xyz="0.0 0.0 0.101" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.12 0.002"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.05 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.004" length="0.10"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.0 -0.05 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.004" length="0.10"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.0 0.0 0.101" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.12 0.002"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0.0 0.0 0.06"/>
      <inertia ixx="0.000046" ixy="0.0" ixz="0.0" iyy="0.000035" iyz="0.0" izz="0.000013"/>
    </inertial>
  </link>

  <joint name="zed2i_camera_joint" type="fixed">
    <parent link="camera_rods_link"/>
    <child link="zed2i_camera_link"/>
    <origin xyz="0.01 0.0 0.1225" rpy="0 0 0"/>
  </joint>

  <link name="zed2i_camera_link">
    <visual>
      <geometry>
        <box size="0.03 0.175 0.043"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.175 0.043"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.16"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000433" ixy="0.0" ixz="0.0" iyy="0.000024" iyz="0.0" izz="0.000421"/>
    </inertial>
  </link>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="zed2i_camera_link"/>
    <child link="camera_link_optical"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>
  <link name="camera_link_optical"/>

  <!-- ==================== ROS2 CONTROL ==================== -->

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <!-- FIX: correct plugin name for gz_ros2_control on Humble/Fortress -->
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ==================== GAZEBO PLUGIN ==================== -->
  <!--
    FIX 1: filename must be "gz_ros2_control-system" (no "lib" prefix, no ".so").
    FIX 2: name attribute must use double-colon namespace syntax.
    FIX 3: Added <robot_param> and <robot_param_node> so the plugin can find
            the URDF on the ROS parameter server.
    FIX 4: Removed the broken <ros><remapping> block. The cmd_vel remapping
            is now done cleanly in the launch file via the controller spawner
            or a standalone topic_tools/relay node.
    FIX 5: Removed <hold_joints> — it belongs INSIDE the plugin tag, not
            in a link. Set to false so wheels are free to rotate on spawn.
  -->
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>$(find minibot_description)/config/controllers.yaml</parameters>
      <hold_joints>false</hold_joints>
    </plugin>
  </gazebo>

  <!-- ==================== WHEEL FRICTION ==================== -->

  <gazebo reference="front_left_caster">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <gazebo reference="front_right_caster">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <gazebo reference="left_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

</robot>